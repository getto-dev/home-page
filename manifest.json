{
  "manifest_version": 3,
  "name": "Закладки на новой вкладке",
  "version": "12.0",
  "description": "Быстрые закладки на новой вкладке",
  "permissions": [
    "bookmarks",
    "favicon",
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "worker.js",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [{
    "resources": ["_favicon/*"],
    "matches": ["<all_urls>"]
  }]
}
