{
  "manifest_version": 3,
  "name": "Закладки на новой вкладке",
  "version": "11.1",
  "description": "Быстрые закладки на новой вкладке с оптимизацией производительности",
  "permissions": [
    "bookmarks",
    "favicon",
    "tabs"
  ],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
